#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MANIFEST="$DOTFILES_ROOT/agents/.agents/skills/manifest.txt"

if ! command -v npx >/dev/null 2>&1; then
  echo "npx is not available after Node setup."
  exit 1
fi

if [ ! -f "$MANIFEST" ]; then
  echo "No skills manifest found, skipping skill installation."
  exit 0
fi

while IFS= read -r skill; do
  if [ -z "$skill" ] || [[ "$skill" = \#* ]]; then
    continue
  fi

  echo "Installing skill: $skill"
  npx skills add "$skill" -g -y
done < "$MANIFEST"
